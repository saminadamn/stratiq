# ---------------------------------------------------------------------------
# Copy to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---------------------------------------------------
POSTGRES_USER=stratiq
POSTGRES_PASSWORD=stratiq_dev_password
POSTGRES_DB=stratiq
# Host-mapped port. Deliberately not 5432: that port is commonly already taken
# by another local Postgres install, and a conflicting listener on the host
# silently steals the connection before it ever reaches this container (no
# bind error is raised — you just get confusing auth failures). Inside the
# Docker network, api/web still reach Postgres at "db:5432" regardless of this.
POSTGRES_PORT=5433
# Used by Prisma when running the API on the host (not in Docker).
DATABASE_URL=postgresql://stratiq:stratiq_dev_password@localhost:5433/stratiq?schema=public

# --- API ----------------------------------------------------------------------
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000
# Set by Render/Railway/Heroku automatically — overrides API_PORT when present.
# Leave unset for local/Docker use.
# PORT=

# JWT: two distinct secrets so a leaked access-token signing key can't be used
# to forge long-lived refresh tokens, and vice versa.
JWT_ACCESS_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string-min-32-chars
JWT_REFRESH_TTL=30d

# Origins allowed to call the API with credentials.
CORS_ORIGIN=http://localhost:5173

# --- Data Management & ETL (Sprint 2) ---------------------------------------
# Relative to apps/api's working directory when not absolute. In Docker this
# is a mounted volume (docker/docker-compose.yml) so uploads persist.
STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=25

# --- Predictive Intelligence (v1.0) -----------------------------------------
# Internal-only — the ML service has no public port. This is a Docker-network
# hostname (http://ml-service:8000) in docker-compose.prod.yml.
ML_SERVICE_URL=http://localhost:8000

# --- Production Readiness (v1.0) --------------------------------------------
LOG_LEVEL=info
# express-rate-limit on every /api/v1 request. Login/signup have their own
# separate, stricter, non-configurable limit (see rate-limit.middleware.ts).
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
# Host port nginx publishes in docker-compose.prod.yml. Only used by the prod
# stack — the dev stack (docker-compose.yml) exposes api/web directly instead.
HTTP_PORT=80

# --- Web ------------------------------------------------------------------
VITE_API_URL=http://localhost:4000
