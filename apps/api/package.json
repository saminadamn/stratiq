{
  "name": "@stratiq/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "worker:dev": "tsx watch --env-file=../../.env src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=../../.env dist/main.js",
    "worker:start": "node --env-file=../../.env dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx --env-file=../../.env prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@stratiq/shared": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.80.1",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pdfkit": "^0.15.1",
    "pino": "^9.14.0",
    "prisma": "^6.1.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/pdfkit": "^0.13.7",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
