// StratIQ database schema.
//
// Design notes (see docs/ARCHITECTURE.md for the full rationale):
// - Role lives on `Membership`, not `User` — a user's permissions are always scoped
//   to one organization, never global, because the same person can hold different
//   roles in different organizations (workspaces).
// - `RefreshToken` stores only a hash of the token, never the token itself, so a
//   database leak doesn't hand out valid sessions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]

  // Sprint 2 (Data Management & ETL) back-relations. Added without touching any
  // existing field above — see docs/ARCHITECTURE.md "Sprint 2" section.
  createdDatasets        Dataset[]
  createdDatasetVersions DatasetVersion[]
  uploadedFiles          UploadedFile[]

  // Sprint 3 (Analytics) back-relation.
  savedDashboardViews SavedDashboardView[]

  // v1.0 (Executive Reporting) back-relation.
  generatedReports Report[]

  @@map("users")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]

  // Sprint 2 back-relations.
  datasets      Dataset[]
  uploadedFiles UploadedFile[]

  // Sprint 3 back-relation.
  savedDashboardViews SavedDashboardView[]

  // Sprint 4 (Analytics Intelligence Layer) back-relations.
  insights      Insight[]
  alerts        Alert[]
  businessRules BusinessRule[]

  // v1.0 (Predictive & Decision Intelligence, Reporting) back-relations.
  mlModels                MlModel[]
  mlFeatureSnapshots      MlFeatureSnapshot[]
  predictions             Prediction[]
  decisionRecommendations DecisionRecommendation[]
  reports                 Report[]

  @@map("organizations")
}

// Join model carrying the role — this *is* the RBAC model. Every authorization
// check resolves a role by looking up (userId, organizationId) here.
model Membership {
  id             String   @id @default(cuid())
  role           Role
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // A user can only hold one role per organization.
  @@unique([userId, organizationId])
  @@map("memberships")
}

// One row per issued refresh token, enabling rotation and revocation. Access
// tokens are intentionally NOT persisted — they're short-lived and stateless.
model RefreshToken {
  id                String    @id @default(cuid())
  tokenHash         String    @unique
  userId            String
  expiresAt         DateTime
  revokedAt         DateTime?
  // Points at the token that replaced this one, so a reused (already-rotated)
  // refresh token is detectable as a replay/theft signal.
  replacedByTokenId String?
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Sprint 2: Data Management & ETL Foundation
//
// Design notes (full rationale in docs/ARCHITECTURE.md):
// - No dynamic `CREATE TABLE` per dataset. Arbitrary user-uploaded schemas are
//   stored as JSONB rows in `DatasetRow` instead — this keeps the schema
//   flexible without runtime DDL (a SQL-injection and migration-management
//   risk) while still living in PostgreSQL as the pipeline diagram requires.
// - A dataset is versioned via `DatasetVersion`, one row per upload/clean
//   result. "Current version" is derived (highest `versionNumber`), not
//   stored as a pointer, so there's no circular FK between Dataset and
//   DatasetVersion to manage.
// - `EtlJob`/`EtlLog` capture one pipeline run and its stage-by-stage output,
//   which is what powers the "Processing Logs" UI.
// ---------------------------------------------------------------------------

enum DatasetStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum CleaningMode {
  NONE
  AUTOMATIC
  MANUAL
}

enum SourceFileType {
  CSV
  XLSX
}

enum EtlJobStatus {
  PENDING
  VALIDATING
  CLEANING
  TRANSFORMING
  FEATURE_ENGINEERING
  SAVING
  COMPLETED
  FAILED
}

enum EtlLogLevel {
  INFO
  WARN
  ERROR
}

// The logical, named dataset a user thinks of as "Sales Dataset". Its actual
// data lives in versions — this row is mostly identity + org ownership.
model Dataset {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  status         DatasetStatus @default(UPLOADING)
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User             @relation(fields: [createdById], references: [id])
  versions     DatasetVersion[]

  @@index([organizationId])
  @@map("datasets")
}

// One immutable snapshot of a dataset: a specific upload or the output of a
// cleaning operation. `schema` records the detected column names/types so the
// UI can render a preview table without re-parsing the source file.
model DatasetVersion {
  id               String       @id @default(cuid())
  datasetId        String
  versionNumber    Int
  uploadedFileId   String?      @unique
  rowCount         Int
  columnCount      Int
  schema           Json
  qualityScore     Int?
  validationReport Json?
  cleaningMode     CleaningMode @default(NONE)
  cleaningLog      Json?
  processingTimeMs Int?
  createdById      String
  createdAt        DateTime     @default(now())

  dataset      Dataset       @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  uploadedFile UploadedFile? @relation(fields: [uploadedFileId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])
  rows         DatasetRow[]
  etlJobs      EtlJob[]
  featureSets  FeatureSet[]

  @@unique([datasetId, versionNumber])
  @@map("dataset_versions")
}

// Row-level storage for a version's tabular data as JSONB — see the file-level
// note above for why this replaces per-dataset SQL tables.
model DatasetRow {
  id               String @id @default(cuid())
  datasetVersionId String
  rowIndex         Int
  data             Json

  datasetVersion DatasetVersion @relation(fields: [datasetVersionId], references: [id], onDelete: Cascade)

  @@index([datasetVersionId, rowIndex])
  @@map("dataset_rows")
}

// Metadata + storage location for a raw uploaded file. The file bytes
// themselves live on disk (or object storage in production) under a
// generated name — never the user-supplied filename — to prevent path
// traversal and filename collisions.
model UploadedFile {
  id               String         @id @default(cuid())
  organizationId   String
  originalFileName String
  storedFileName   String
  storagePath      String
  fileType         SourceFileType
  mimeType         String
  fileSizeBytes    Int
  checksumSha256   String
  uploadedById     String
  createdAt        DateTime       @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy     User            @relation(fields: [uploadedById], references: [id])
  datasetVersion DatasetVersion?

  @@index([organizationId])
  @@map("uploaded_files")
}

// One pipeline run (upload → validation → cleaning → transformation →
// feature engineering → saving) for a single dataset version.
model EtlJob {
  id               String       @id @default(cuid())
  datasetVersionId String
  status           EtlJobStatus @default(PENDING)
  startedAt        DateTime     @default(now())
  completedAt      DateTime?
  errorMessage     String?

  datasetVersion DatasetVersion @relation(fields: [datasetVersionId], references: [id], onDelete: Cascade)
  logs           EtlLog[]

  @@index([datasetVersionId])
  @@map("etl_jobs")
}

// Stage-by-stage log lines for one EtlJob — what the "Processing Logs" UI reads.
model EtlLog {
  id        String      @id @default(cuid())
  etlJobId  String
  stage     String
  level     EtlLogLevel @default(INFO)
  message   String
  createdAt DateTime    @default(now())

  etlJob EtlJob @relation(fields: [etlJobId], references: [id], onDelete: Cascade)

  @@index([etlJobId])
  @@map("etl_logs")
}

// A computed business metric for a dataset version (e.g. Average Order
// Value). `value` is a JSON scalar or breakdown (e.g. a monthly series) since
// metrics vary in shape.
model FeatureSet {
  id               String   @id @default(cuid())
  datasetVersionId String
  name             String
  label            String
  value            Json
  createdAt        DateTime @default(now())

  datasetVersion DatasetVersion @relation(fields: [datasetVersionId], references: [id], onDelete: Cascade)

  @@unique([datasetVersionId, name])
  @@map("feature_sets")
}

// ---------------------------------------------------------------------------
// Sprint 3: Business Intelligence & Analytics Engine
//
// Design notes (full rationale in docs/ARCHITECTURE.md):
// - Analytics has no dedicated fact tables of its own — it computes on top of
//   Sprint 2's DatasetRow JSONB storage, choosing an organization's latest
//   READY dataset (or an explicit override) as its data source. The only new
//   persisted concept this sprint introduces is a *saved filter preset*.
// - Filters are stored as JSON rather than normalized columns because the
//   filter shape (date range, category, region, product, segment) is a
//   frontend/API contract (packages/shared), not something the database
//   needs to query into.
// ---------------------------------------------------------------------------

enum DashboardType {
  EXECUTIVE
  CUSTOMER
  PRODUCT
  INVENTORY
}

model SavedDashboardView {
  id             String        @id @default(cuid())
  organizationId String
  createdById    String
  name           String
  dashboardType  DashboardType
  filters        Json
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId, dashboardType])
  @@map("saved_dashboard_views")
}

// ---------------------------------------------------------------------------
// Sprint 4: Analytics Intelligence Layer
//
// Design notes (full rationale in docs/ARCHITECTURE.md):
// - MetricDefinition is the Metrics Registry: global reference metadata
//   (name/description/category/formula/unit/owner/refreshPolicy), seeded
//   idempotently at startup. It is NOT organization-scoped — it describes
//   metric *types*, not an organization's data. The actual calculation
//   functions live in code (application/analytics/intelligence/metric-
//   calculators.ts), reusing Sprint 3's KPI engine — this table is metadata
//   only, same split real metrics-layer platforms use.
// - Trends and benchmarks are NOT persisted here — they're computed live,
//   same on-demand model as every other Sprint 3 dashboard. Insights and
//   Alerts ARE persisted, because "Insight Timeline" and "historical
//   tracking" are explicit requirements: they're business events, not
//   derived views.
// - Insights/Alerts are generated once per immutable DatasetVersion and then
//   read from storage on subsequent requests (same immutability-enables-
//   caching trick as Sprint 3's analytics cache) — a `refresh` flag creates a
//   new timeline entry rather than overwriting history.
// ---------------------------------------------------------------------------

enum MetricCategory {
  REVENUE
  PROFITABILITY
  CUSTOMER
  PRODUCT
  INVENTORY
  GROWTH
}

enum MetricUnit {
  CURRENCY
  PERCENTAGE
  COUNT
  RATIO
}

enum MetricRefreshPolicy {
  REALTIME
  DAILY
  ON_DATASET_UPLOAD
}

model MetricDefinition {
  id            String              @id @default(cuid())
  key           String              @unique
  name          String
  description   String
  category      MetricCategory
  formula       String
  unit          MetricUnit
  owner         String
  refreshPolicy MetricRefreshPolicy
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("metric_definitions")
}

enum TrendDirection {
  INCREASING
  STABLE
  DECLINING
  SEASONAL
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL
}

model Insight {
  id               String          @id @default(cuid())
  organizationId   String
  datasetVersionId String
  metricKey        String
  title            String
  narrative        String
  trend            TrendDirection?
  severity         InsightSeverity
  currentValue     Float
  previousValue    Float?
  changePercent    Float?
  // Extra structured context (triggered rule ids, outlier periods) — kept as
  // JSON rather than new columns since its shape varies per insight and
  // nothing needs to query into it relationally.
  metadata         Json?
  createdAt        DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([datasetVersionId])
  @@map("insights")
}

enum AlertSeverity {
  INFORMATIONAL
  WARNING
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model Alert {
  id               String        @id @default(cuid())
  organizationId   String
  datasetVersionId String
  metricKey        String
  ruleId           String?
  severity         AlertSeverity
  message          String
  currentValue     Float
  thresholdValue   Float?
  status           AlertStatus   @default(OPEN)
  createdAt        DateTime      @default(now())
  resolvedAt       DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // A deleted rule shouldn't take its historical alerts down with it —
  // SetNull keeps the alert as a record of "something fired," even if the
  // rule that fired it no longer exists.
  rule         BusinessRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([datasetVersionId])
  @@map("alerts")
}

enum RuleComparator {
  VALUE_ABOVE
  VALUE_BELOW
  PERCENT_CHANGE_ABOVE
  PERCENT_CHANGE_BELOW
}

model BusinessRule {
  id             String         @id @default(cuid())
  organizationId String
  metricKey      String
  name           String
  comparator     RuleComparator
  thresholdValue Float
  severity       AlertSeverity
  isActive       Boolean        @default(true)
  // Marks a rule as one of the lazily-seeded defaults (see
  // default-business-rules.ts) rather than something a user configured —
  // informational only, doesn't change evaluation.
  isDefault      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  alerts       Alert[]

  // There is also a partial unique index — CREATE UNIQUE INDEX ON
  // business_rules (organizationId, name) WHERE isDefault — added by
  // migration 20260710150412 to guard concurrent default-rule seeding.
  // Prisma's schema DSL has no partial-index syntax, so it isn't declared
  // here; `prisma migrate dev` will not see it as schema drift because no
  // model change corresponds to it, but don't be surprised it doesn't show
  // up if you inspect this file alone — see ensure-default-business-rules.ts.
  @@index([organizationId, metricKey])
  @@map("business_rules")
}

// v1.0 — Predictive Intelligence (Module 1).
enum MlModelKey {
  CHURN
  FORECAST
  SEGMENTATION
  RECOMMENDATION
}

// One trained artifact instance, scoped to the exact dataset version it was
// trained on — the same "generate once per immutable DatasetVersion, reuse
// after" pattern as Insight/Alert generation (see docs/ARCHITECTURE.md).
// Training happens on demand the first time a prediction is requested for a
// given (organizationId, datasetVersionId, modelKey); later requests for the
// same dataset version load the persisted artifact instead of retraining.
model MlModel {
  id               String     @id @default(cuid())
  organizationId   String
  datasetVersionId String
  modelKey         MlModelKey
  version          Int
  algorithm        String
  // Training metrics (e.g. accuracy, silhouette score) — shape varies per
  // model type, so JSON rather than fixed columns, same reasoning as
  // Insight.metadata.
  metricsJson      Json
  // Path to the joblib-serialized artifact under the ML service's model
  // store volume — mirrors how LocalFileStorage tracks uploaded files by
  // path rather than storing bytes in Postgres.
  artifactPath     String
  isActive         Boolean    @default(true)
  trainedAt        DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, datasetVersionId, modelKey])
  @@index([organizationId, datasetVersionId])
  // findByDatasetVersion queries by (datasetVersionId, modelKey) alone — a
  // dataset version already belongs to exactly one organization, so
  // organizationId isn't part of that lookup. Without this, the query can
  // only use the two indexes above by scanning them in full, since neither
  // leads with datasetVersionId.
  @@index([datasetVersionId, modelKey])
  @@map("ml_models")
}

// The Feature Store: reproducible, inspectable feature vectors per entity,
// built once per dataset version from the same AnalyticsColumns/row-metrics
// helpers every other analytics service uses (see metric-calculators.ts) —
// not a second definition of "what is this customer's total spend."
model MlFeatureSnapshot {
  id               String   @id @default(cuid())
  organizationId   String
  datasetVersionId String
  // "CUSTOMER" | "PRODUCT" — which kind of entity these features describe.
  entityType       String
  entityId         String
  featuresJson     Json
  computedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, datasetVersionId, entityType, entityId])
  @@index([organizationId, datasetVersionId, entityType])
  // findByDatasetVersion queries by (datasetVersionId, entityType) alone —
  // same reasoning as MlModel's extra index above.
  @@index([datasetVersionId, entityType])
  @@map("ml_feature_snapshots")
}

// A persisted prediction result. targetType/targetId identify what the
// prediction is about (a customer for churn/segmentation, a product for
// recommendations, null for a dataset-wide forecast) — kept as plain strings
// rather than a formal relation since the target may be a customerId that
// only exists inside DatasetRow's JSONB, not a first-class table.
model Prediction {
  id               String     @id @default(cuid())
  organizationId   String
  datasetVersionId String
  modelKey         MlModelKey
  modelVersion     Int
  targetType       String?
  targetId         String?
  valueJson        Json
  confidence       Float
  // Feature-importance explanation for this specific prediction — see
  // Module 1's explainability decision (native importances, not SHAP).
  explanationJson  Json
  createdAt        DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, datasetVersionId, modelKey])
  // findByDatasetVersion queries by (datasetVersionId, modelKey) alone —
  // same reasoning as MlModel's extra index above.
  @@index([datasetVersionId, modelKey])
  @@map("predictions")
}

// v1.0 — Decision Intelligence (Module 2).
enum DecisionCategory {
  ROOT_CAUSE
  RECOMMENDATION
}

enum RecommendationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Deterministic output of the Decision Intelligence Engine — every row here
// traces back to concrete Insight/Alert/Benchmark/Prediction inputs recorded
// in sourceRefsJson, never to freeform generation (no LLM is used anywhere
// in this engine, per its explicit requirement).
model DecisionRecommendation {
  id                 String                 @id @default(cuid())
  organizationId     String
  datasetVersionId   String
  category           DecisionCategory
  title              String
  rootCause          String?
  recommendationText String?
  roiEstimate        Float?
  impactScore        Float
  priority           RecommendationPriority
  actionPlanJson     Json?
  sourceRefsJson     Json
  createdAt          DateTime               @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Generation is table-driven (same root cause/alert/prediction always
  // yields the same title for a given dataset version), so this constraint
  // plus createMany(skipDuplicates) is the DB-level guard against duplicate
  // generation — no in-process lock needed (contrast with Sprint 4's
  // original GenerateIntelligenceService lock, retrofitted in Module 5).
  // `category` is part of the key, not just `title`: a root cause and its
  // corresponding recommendation can legitimately share similar wording
  // (e.g. both about "Revenue declined") without one silently shadowing
  // the other under skipDuplicates.
  @@unique([organizationId, datasetVersionId, category, title])
  @@index([organizationId, createdAt])
  @@index([datasetVersionId])
  @@map("decision_recommendations")
}

// v1.0 — Executive Reporting (Module 3).
enum ReportType {
  EXECUTIVE_SUMMARY
  KPI
  PREDICTION
  RECOMMENDATION
}

// v1.1 (Distributed Systems Showcase). PENDING/PROCESSING exist because
// generation moved off the request path onto a queue (see
// docs/adr/0007-bullmq-job-queue.md) — a row is now created the moment a
// report is *requested*, before the file exists, not just once generation
// succeeds.
enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

// One row per requested PDF — the "Report History" / "Download Center" is
// just this table plus LocalFileStorage, the same split already used for
// uploaded datasets (metadata in Postgres, bytes on disk by path).
model Report {
  id               String       @id @default(cuid())
  organizationId   String
  datasetVersionId String
  type             ReportType
  // Defaults to COMPLETE: every row created before this migration finished
  // generation synchronously, so backfilling that status is simply correct,
  // not a placeholder. New rows always pass an explicit status at creation.
  status           ReportStatus @default(COMPLETE)
  // Unknown until the async job finishes — null while PENDING/PROCESSING.
  fileName         String?
  storagePath      String?
  errorMessage     String?
  generatedById    String
  generatedAt      DateTime     @default(now())
  completedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedBy  User         @relation(fields: [generatedById], references: [id])

  @@index([organizationId, generatedAt])
  @@index([organizationId, status])
  @@map("reports")
}
